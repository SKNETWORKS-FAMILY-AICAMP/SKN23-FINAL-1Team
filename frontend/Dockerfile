FROM node:24-bookworm-slim

WORKDIR /app

ARG NEXT_PUBLIC_PORTONE_STORE_ID
ARG NEXT_PUBLIC_IAMPORT_MERCHANT_CODE
ARG NEXT_PUBLIC_PORTONE_CHANNEL_KEY
ARG NEXT_PUBLIC_PORTONE_KAKAOPAY_CHANNEL_KEY
ARG NEXT_PUBLIC_PORTONE_TOSSPAY_CHANNEL_KEY
ARG NEXT_PUBLIC_PORTONE_INICIS_CHANNEL_KEY
ARG NEXT_PUBLIC_PORTONE_DANAL_CHANNEL_KEY

ENV NEXT_PUBLIC_PORTONE_STORE_ID=$NEXT_PUBLIC_PORTONE_STORE_ID
ENV NEXT_PUBLIC_IAMPORT_MERCHANT_CODE=$NEXT_PUBLIC_IAMPORT_MERCHANT_CODE
ENV NEXT_PUBLIC_PORTONE_CHANNEL_KEY=$NEXT_PUBLIC_PORTONE_CHANNEL_KEY
ENV NEXT_PUBLIC_PORTONE_KAKAOPAY_CHANNEL_KEY=$NEXT_PUBLIC_PORTONE_KAKAOPAY_CHANNEL_KEY
ENV NEXT_PUBLIC_PORTONE_TOSSPAY_CHANNEL_KEY=$NEXT_PUBLIC_PORTONE_TOSSPAY_CHANNEL_KEY
ENV NEXT_PUBLIC_PORTONE_INICIS_CHANNEL_KEY=$NEXT_PUBLIC_PORTONE_INICIS_CHANNEL_KEY
ENV NEXT_PUBLIC_PORTONE_DANAL_CHANNEL_KEY=$NEXT_PUBLIC_PORTONE_DANAL_CHANNEL_KEY

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "--hostname", "0.0.0.0", "--port", "3000"]
